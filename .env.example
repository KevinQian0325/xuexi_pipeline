# 复制为 .env 后填写真实值。
# .env 已加入 .gitignore，不要提交真实密钥。

XUEXI_APP_ID=
XUEXI_ACCESS_TOKEN=

# 结果文件存储根目录。程序会自动在此目录下创建“结果文件”文件夹。
# 例如：/Users/kevinqian/Desktop/1 -> /Users/kevinqian/Desktop/1/结果文件
XUEXI_RESULT_STORAGE_ROOT_DIR=

# 以下两项通常不用改；服务地址或资源 ID 变更时再覆盖。
XUEXI_RECOGNIZE_URL="https://openspeech.bytedance.com/api/v3/auc/bigmodel/recognize/flash"
XUEXI_RESOURCE_ID="volc.bigasr.auc_turbo"
